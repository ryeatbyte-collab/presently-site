# PRESENTLY 인스타그램 자동화 환경변수
# 이 파일을 .env 로 복사하고 값을 채워주세요
# cp .env.example .env

# ── Claude API ────────────────────────────────────────
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Instagram Graph API ───────────────────────────────
# 아래 README.md의 Instagram API 설정 가이드 참고

# Instagram Business 계정 User ID
# https://graph.facebook.com/me?access_token=YOUR_TOKEN 로 확인
IG_USER_ID=17841400000000000

# Long-lived access token (60일 유효)
# 또는 System User token (무기한)
IG_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 이미지 호스팅 ─────────────────────────────────────
# 생성된 이미지를 공개 URL로 서빙하는 위치
# Instagram API는 로컬 파일을 직접 받지 않고 공개 URL만 허용
# 옵션 1: GitHub Pages (무료)
#   IMAGE_HOSTING_URL=https://yourusername.github.io/presently-images/
# 옵션 2: Cloudflare R2 (무료 10GB/월)
#   IMAGE_HOSTING_URL=https://pub-xxxx.r2.dev/
# 옵션 3: AWS S3 Public Bucket
#   IMAGE_HOSTING_URL=https://your-bucket.s3.ap-northeast-2.amazonaws.com/
IMAGE_HOSTING_URL=https://your-image-server.com/images/
